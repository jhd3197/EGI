# EGI gitignore

# Working plans and scratchpads (keep these local only)
docs/plans/
docs/plans/*
plan*.md
PLAN*.md
/test.md
test.md

# Python bytecode (anywhere, not just server/)
__pycache__/
*.py[cod]

# Python packaging (egi CLI editable install)
*.egg-info/
build/
dist/
/data/

# Python / FastAPI
server/.venv/
server/__pycache__/
server/**/*.pyc
server/.env
server/.pytest_cache/
server/.mypy_cache/
server/data/
server/uploads/
server/*.db

# Backups (egi backup output) — never commit crisis data snapshots
server/backups/
*.tar.gz

# Node / JS tooling
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/coverage/

# Android / Kotlin
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/.idea/
mobile/android/*.iml
mobile/android/app/build/
mobile/android/build/
# Copied PWA build output (frontend/dist → assets/www), regenerated by the
# :app:copyWebAssets Gradle task on every build. Never commit it (it carries
# hash-named font/JS bundles that churn each build).
mobile/android/app/src/main/assets/www/
mobile/android/captures/
mobile/android/.externalNativeBuild/
mobile/android/.cxx/
mobile/android/.kotlin/
# Firebase Cloud Messaging creds — optional (Phase 6) and never committed.
# Contributors drop their own; google-services.json.example is the template.
mobile/android/app/google-services.json

# macOS / Windows
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Misc
*.log
.env
.env.local
*.zip
image*.png
image*.jpg
vargas.md
/mobile/android/screenshots
# Smoke-test artifacts (screenshots, console logs, verdicts) — regenerated each run.
/mobile/android/test-results
.claude/scheduled_tasks.lock

# Generated UX audit reports (plan-29)
docs/ux-audit/reports/
.pr/*