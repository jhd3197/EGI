{
  "name": "egi-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EGI offline-first PWA — React + Vite frontend",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check:offline": "node scripts/check-offline-assets.mjs",
    "check:i18n": "node scripts/i18n-check.js",
    "ux:contrast": "node scripts/ux-contrast.mjs",
    "ux:audit": "node scripts/ux-audit.mjs",
    "ux:lighthouse": "lighthouse http://localhost:3000 --only-categories=performance,accessibility,best-practices,seo --chrome-flags=\"--headless\" --output=html --output-path=../docs/ux-audit/reports/lighthouse.html",
    "ux:axe": "axe http://localhost:3000",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
