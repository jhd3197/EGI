PORT=3000
DB_PATH=./data/egi.db
UPLOAD_DIR=./uploads

# ─── Security (plan-07) ──────────────────────────────────────────────────────
# Deployment mode. Anything other than "development" is treated as production,
# which locks CORS down (see ALLOWED_ORIGINS). Always set ENV=production for a
# public deployment.
ENV=production

# Cross-origin access. Comma-separated list of allowed browser origins.
# The PWA is served same-origin by this server, so most deployments need NONE.
# Only add origins for separately-hosted clients. NEVER use "*" in production.
#   ALLOWED_ORIGINS=https://egi.example.org,https://app.example.org
# In ENV=development with this unset, all origins are allowed for convenience.
ALLOWED_ORIGINS=

# Optional Content-Security-Policy header (off unless set). The PWA uses inline
# styles, so a CSP must allow them. Recommended starting value:
#   CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'
CONTENT_SECURITY_POLICY=

# Rate limiting on write endpoints (/sync, /import/paper, /normalize,
# /sms/webhook, /persons/{id}/reports). In-memory, per client IP, per worker.
#   RATE_LIMIT_MAX     max writes per IP per window (0 disables limiting)
#   RATE_LIMIT_WINDOW  window length in seconds
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=300
# Comma-separated IPs that bypass the limit (trusted operators / gateways).
RATE_LIMIT_TRUSTED_IPS=
# Set to true ONLY behind a trusted reverse proxy that sets X-Forwarded-For,
# so the real client IP (not the proxy's) is rate-limited.
RATE_LIMIT_TRUST_FORWARDED=false

# Operator (moderator) auth. Comma-separated secure random bearer tokens.
# Protected endpoints (moderation approve/reject, duplicate merge/reject,
# OCR review, the audit log) require: Authorization: Bearer <token>.
# Generate a token with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If LEFT EMPTY, operator auth is DISABLED (dev only) — set this in production.
# Rotate by replacing the values and restarting.
OPERATOR_TOKENS=

# Uploaded photos. High-risk crisis data, so DISABLED by default. When false,
# photo URLs are stripped from public search and the /uploads route returns 403.
# When true, photos are still served ONLY through the operator-gated
# GET /uploads/{filename} route (never a public static mount). EXIF metadata is
# always stripped on upload regardless of this flag.
ENABLE_PHOTOS=false

# Data retention (plan-07 §11). Records carry an optional `retained_until`
# instant; past that, `egi retention-review` lists them and `egi anonymize`
# strips PII while keeping status counts. Recommended policy: keep for the
# duration of the event + 90 days, then operator review. Retention is
# operator-driven via the CLI; no env knob is required.
# ─────────────────────────────────────────────────────────────────────────────

# Path to the built frontend (Vite output), relative to server/ by default.
# Run `npm run build` in ../frontend to generate it.
FRONTEND_DIR=../frontend/dist

# Tesseract command. On Windows with Chocolatey/Installer usually:
# TESSERACT_CMD="C:\\Program Files\\Tesseract-OCR\\tesseract.exe"
TESSERACT_CMD=tesseract

# Optional: LLM extraction for OCR records using Prompture.
# Format: provider/model. Examples:
#   openai/gpt-4o-mini
#   groq/llama-3.1-8b-instant
#   ollama/llama3.1:8b
# Auth env vars are provider-specific, e.g. OPENAI_API_KEY, GROQ_API_KEY.
# If unset, OCR records are created with raw text only and must be completed manually.
LLM_MODEL=openai/gpt-4o-mini

# Local-first AI base (server/ai.py), used by /normalize and as the OCR fallback
# when LLM_MODEL is unset. Default provider is Ollama (local, no API key).
#   AI_PROVIDER=ollama      # or "openai"
#   AI_MODEL=llama3.1:8b    # provider-specific model name
#   OLLAMA_HOST=http://localhost:11434
# OpenAI uses the standard OPENAI_API_KEY / OPENAI_BASE_URL env vars.
AI_PROVIDER=ollama
