PORT=3000
DB_PATH=./data/egi.db
UPLOAD_DIR=./uploads

# ─── Security (plan-07) ──────────────────────────────────────────────────────
# Deployment mode. Anything other than "development" is treated as production,
# which locks CORS down (see ALLOWED_ORIGINS). Always set ENV=production for a
# public deployment.
ENV=production

# Cross-origin access. Comma-separated list of allowed browser origins.
# The PWA is served same-origin by this server, so most deployments need NONE.
# Only add origins for separately-hosted clients. NEVER use "*" in production.
#   ALLOWED_ORIGINS=https://egi.example.org,https://app.example.org
# In ENV=development with this unset, all origins are allowed for convenience.
ALLOWED_ORIGINS=

# Optional Content-Security-Policy header (off unless set). The PWA uses inline
# styles, so a CSP must allow them. Recommended starting value:
#   CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'
CONTENT_SECURITY_POLICY=

# Rate limiting on write endpoints (/sync, /import/paper, /normalize,
# /sms/webhook, /persons/{id}/reports). In-memory, per client IP, per worker.
#   RATE_LIMIT_MAX     max writes per IP per window (0 disables limiting)
#   RATE_LIMIT_WINDOW  window length in seconds
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=300
# Comma-separated IPs that bypass the limit (trusted operators / gateways).
RATE_LIMIT_TRUSTED_IPS=
# Set to true ONLY behind a trusted reverse proxy that sets X-Forwarded-For,
# so the real client IP (not the proxy's) is rate-limited.
RATE_LIMIT_TRUST_FORWARDED=false

# ─── Auth: user accounts & RBAC (plan-08) ────────────────────────────────────
# The server uses real user accounts with bcrypt-hashed passwords and role-based
# access control (viewer < operator < commander < admin). Clients still send
# Authorization: Bearer <token>; log in at POST /auth/login to get a token.
# Manage accounts with the CLI: `egi user create --email you@org --role admin`.
#
# DEPRECATED — OPERATOR_TOKENS: comma-separated static bearer tokens. Still
# accepted (operator-level only) during a migration window and logged as
# deprecated; support will be removed in a future release. On first startup, if
# this is set and no users exist yet, the server bootstraps an admin account
# with a random password and prints it ONCE — log in, create real users, then
# remove this variable.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If LEFT EMPTY and no users exist, auth is DISABLED (dev only).
OPERATOR_TOKENS=
# Email for the one-time bootstrap admin (defaults to admin@egi.local).
BOOTSTRAP_ADMIN_EMAIL=admin@egi.local

# Uploaded photos. High-risk crisis data, so DISABLED by default. When false,
# photo URLs are stripped from public search and the /uploads route returns 403.
# When true, photos are still served ONLY through the operator-gated
# GET /uploads/{filename} route (never a public static mount). EXIF metadata is
# always stripped on upload regardless of this flag.
ENABLE_PHOTOS=false

# Data retention (plan-07 §11). Records carry an optional `retained_until`
# instant; past that, `egi retention-review` lists them and `egi anonymize`
# strips PII while keeping status counts. Recommended policy: keep for the
# duration of the event + 90 days, then operator review. Retention is
# operator-driven via the CLI; no env knob is required.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Communications hub (plan-11) ────────────────────────────────────────────
# Unified SMS / email / push messaging. Every channel has a pluggable provider;
# the DEFAULT for all of them is "log" — messages are recorded as sent without
# any external call, so dev/demo/tests work with ZERO credentials. Set a real
# driver only when you have a gateway. Providers can also be configured at
# runtime via the /message-providers admin API (a config change, not code).
#
# Public base URL used to build links in emails (e.g. password reset).
PUBLIC_BASE_URL=http://localhost:3000
#
# SMS. SMS_PROVIDER: log (default) | twilio
SMS_PROVIDER=log
# Twilio (only if SMS_PROVIDER=twilio):
#   TWILIO_ACCOUNT_SID=ACxxxxxxxx
#   TWILIO_AUTH_TOKEN=xxxxxxxx
#   TWILIO_FROM=+15555550123
#
# Email. EMAIL_PROVIDER: log (default) | smtp
EMAIL_PROVIDER=log
# SMTP (only if EMAIL_PROVIDER=smtp):
#   SMTP_HOST=smtp.example.org
#   SMTP_PORT=587
#   SMTP_USER=egi@example.org
#   SMTP_PASSWORD=xxxxxxxx
#   SMTP_FROM=egi@example.org
#   SMTP_USE_TLS=true
#
# Push. PUSH_PROVIDER: log (default) | webpush | fcm
PUSH_PROVIDER=log
# Web Push (VAPID) for the PWA. Generate a key pair once (e.g. `vapid --gen` or
# the py-vapid CLI). The public key is exposed at GET /push/vapid-public-key.
# Real delivery also needs the optional `pywebpush` package installed.
#   VAPID_PUBLIC_KEY=
#   VAPID_PRIVATE_KEY=
#   VAPID_SUBJECT=mailto:egi@example.org
# Firebase Cloud Messaging for Android:
#   FCM_SERVER_KEY=
# ─────────────────────────────────────────────────────────────────────────────

# ─── Interoperability & federation (plan-12) ────────────────────────────────
# CSV/Excel import-export, PDF flyers, webhooks and server-to-server federation
# work with zero config. These knobs are optional tuning only:
#   WEBHOOK_TIMEOUT=10          # seconds per delivery attempt
#   WEBHOOK_MAX_ATTEMPTS=5      # retry cap before a delivery is abandoned
#   FEDERATION_TIMEOUT=30       # seconds per peer pull/push request
# Webhook subscriptions carry their own per-subscription `secret` (used to sign
# deliveries with HMAC-SHA256); trusted peers carry their own pinned public_key
# and optional bearer token — both are stored in the DB, not here.

# ─── Inclusive crisis access: chatbots & voice (plan-14) ─────────────────────
# WhatsApp + Telegram bots and voice transcription. Like the rest of the comms
# hub, the DEFAULT driver for every channel is "log" — the bots run end to end
# (drafts land in the moderation queue, replies are logged) with ZERO credentials,
# so dev/demo/tests work out of the box. Set a real driver only when you have a
# gateway. Webhook routes: POST /webhooks/whatsapp, POST /webhooks/telegram.
#
# WhatsApp. WHATSAPP_PROVIDER: log (default) | twilio | meta
WHATSAPP_PROVIDER=log
# Twilio WhatsApp (reuses the SMS account; note the dedicated WhatsApp sender):
#   TWILIO_ACCOUNT_SID=ACxxxxxxxx
#   TWILIO_AUTH_TOKEN=xxxxxxxx
#   TWILIO_WHATSAPP_FROM=+14155238886
# Meta WhatsApp Cloud API:
#   WHATSAPP_ACCESS_TOKEN=xxxxxxxx
#   WHATSAPP_PHONE_NUMBER_ID=xxxxxxxx
#
# Telegram. TELEGRAM_PROVIDER: log (default) | telegram
TELEGRAM_PROVIDER=log
# Telegram Bot API (from @BotFather). Set the webhook to POST /webhooks/telegram:
#   TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#
# Voice notes (plan-14 §6). On-device transcription (Android/Web Speech API) is
# preferred; this is the server-side fallback for WhatsApp/Telegram voice notes.
# Needs an optional backend (pip install faster-whisper) or it degrades to None
# and /voice/transcribe returns 503.
#   WHISPER_MODEL=base
# ─────────────────────────────────────────────────────────────────────────────

# Path to the built frontend (Vite output), relative to server/ by default.
# Run `npm run build` in ../frontend to generate it.
FRONTEND_DIR=../frontend/dist

# Tesseract command. On Windows with Chocolatey/Installer usually:
# TESSERACT_CMD="C:\\Program Files\\Tesseract-OCR\\tesseract.exe"
TESSERACT_CMD=tesseract

# Optional: LLM extraction for OCR records using Prompture.
# Format: provider/model. Examples:
#   openai/gpt-4o-mini
#   groq/llama-3.1-8b-instant
#   ollama/llama3.1:8b
# Auth env vars are provider-specific, e.g. OPENAI_API_KEY, GROQ_API_KEY.
# If unset, OCR records are created with raw text only and must be completed manually.
LLM_MODEL=openai/gpt-4o-mini

# Local-first AI base (server/ai.py), used by /normalize and as the OCR fallback
# when LLM_MODEL is unset. Default provider is Ollama (local, no API key).
#   AI_PROVIDER=ollama      # or "openai"
#   AI_MODEL=llama3.1:8b    # provider-specific model name
#   OLLAMA_HOST=http://localhost:11434
# OpenAI uses the standard OPENAI_API_KEY / OPENAI_BASE_URL env vars.
AI_PROVIDER=ollama

# ─── Observability & operations (plan-15) ────────────────────────────────────
# Structured logging. LOG_FORMAT: "json" (default in production) ships one JSON
# object per line for Loki/Datadog/CloudWatch; "text" (default in development) is
# human-readable. LOG_LEVEL: DEBUG/INFO/WARNING/ERROR (default INFO).
LOG_FORMAT=
LOG_LEVEL=INFO

# /health fails the uploads check below this many free bytes (default 100 MB).
MIN_FREE_BYTES=104857600

# Where `egi backup` writes (and where /metrics looks for the last backup time).
# Defaults to server/backups when unset.
BACKUP_DIR=

# Automated backup retention + offsite (plan-15 Phase 3). Older local backups are
# pruned past BACKUP_RETENTION_DAYS. Set BACKUP_ENCRYPT_KEY to symmetrically
# encrypt tarballs (AES-GCM) before they leave the box; store the key SEPARATELY
# from the backups. S3-compatible offsite upload (Backblaze B2/MinIO/AWS/Wasabi)
# uses the standard AWS env vars + the endpoint/bucket below.
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPT_KEY=
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION come from the env.

# PostgreSQL migration path (plan-15 Phase 4). SQLite stays the default; set this
# to opt into Postgres once the migration runner supports your deployment.
#   DATABASE_URL=postgresql://egi:secret@localhost:5432/egi
DATABASE_URL=
